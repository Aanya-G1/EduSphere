<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.text.Font?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.FeedController" style="-fx-background-color: #CAF0F8">	
	<center>
		<ScrollPane fitToWidth="true" maxWidth="600" style="-fx-background-color:transparent;">
			<VBox fx:id="feedContainer" style="-fx-background-color: #F2D965;-fx-padding: 20; -fx-min-height: 800;" spacing="10" alignment="CENTER" />
		</ScrollPane>
	</center>
	<top>
		<HBox alignment="CENTER" style="-fx-background-color:#FFF9F0" spacing="10">
			<TextField fx:id="searchBar" promptText="search..."/>
			<Button fx:id="searchBtn" text="Search" onAction="#searchPosts"/>
		</HBox>
	</top>
	<left>
		<MenuBar>
			<Menu text="Posts">
				<MenuItem fx:id="addPost" text="Add Post" onAction="#openAddPost"/>
				<MenuItem text="Your Posts"/>
			</Menu>
		</MenuBar>
	</left>

</BorderPane>